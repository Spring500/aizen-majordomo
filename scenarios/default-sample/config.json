{
  "cardTypes": [
    {
      "id": "task",
      "name": "Task",
      "description": "普通事项",
      "system": true,
      "enabled": true,
      "position": 1,
      "fields": [
        { "id": "title", "label": "标题", "kind": "text", "required": true, "system": true },
        { "id": "body", "label": "正文", "kind": "longText", "system": true },
        { "id": "priority", "label": "优先级", "kind": "number", "defaultValue": 0, "system": true },
        { "id": "lane", "label": "Lane", "kind": "text", "system": true },
        { "id": "assignee", "label": "负责人", "kind": "actor", "system": true },
        {
          "id": "risk_level",
          "label": "风险等级",
          "kind": "enum",
          "defaultValue": "normal",
          "system": true,
          "options": [
            { "value": "low", "label": "低" },
            { "value": "normal", "label": "普通" },
            { "value": "high", "label": "高" }
          ]
        }
      ],
      "actions": [
        {
          "id": "create",
          "label": "创建",
          "kind": "create",
          "system": true,
          "writableFields": ["title", "body", "priority", "lane", "assignee", "risk_level"],
          "requiredFields": ["title"]
        },
        {
          "id": "update",
          "label": "编辑",
          "kind": "update",
          "system": true,
          "writableFields": ["title", "body", "priority", "lane", "assignee", "risk_level"]
        },
        { "id": "comment", "label": "评论", "kind": "comment", "system": true, "writableFields": [] },
        { "id": "transition", "label": "流转", "kind": "transition", "system": true, "writableFields": [] }
      ]
    },
    {
      "id": "decision",
      "name": "Decision",
      "description": "需要人类正式回复的问题",
      "system": true,
      "enabled": true,
      "position": 2,
      "fields": [
        { "id": "title", "label": "标题", "kind": "text", "required": true, "system": true },
        { "id": "body", "label": "正文", "kind": "longText", "system": true },
        { "id": "priority", "label": "优先级", "kind": "number", "defaultValue": 0, "system": true },
        { "id": "lane", "label": "Lane", "kind": "text", "system": true },
        { "id": "assignee", "label": "负责人", "kind": "actor", "system": true },
        {
          "id": "risk_level",
          "label": "风险等级",
          "kind": "enum",
          "defaultValue": "normal",
          "system": true,
          "options": [
            { "value": "low", "label": "低" },
            { "value": "normal", "label": "普通" },
            { "value": "high", "label": "高" }
          ]
        },
        { "id": "options", "label": "选项", "kind": "stringList", "system": true },
        { "id": "reply", "label": "正式回复", "kind": "longText", "system": true }
      ],
      "actions": [
        {
          "id": "create",
          "label": "创建",
          "kind": "create",
          "system": true,
          "writableFields": ["title", "body", "priority", "lane", "assignee", "risk_level", "options"],
          "requiredFields": ["title"]
        },
        {
          "id": "update",
          "label": "编辑",
          "kind": "update",
          "system": true,
          "writableFields": ["title", "body", "priority", "lane", "assignee", "risk_level", "options"]
        },
        {
          "id": "reply",
          "label": "正式回复",
          "kind": "reply",
          "system": true,
          "writableFields": ["reply"],
          "requiredFields": ["reply"]
        }
      ]
    },
    {
      "id": "memo",
      "name": "Memo",
      "description": "备忘记录",
      "system": true,
      "enabled": true,
      "position": 3,
      "fields": [
        { "id": "title", "label": "标题", "kind": "text", "required": true, "system": true },
        { "id": "body", "label": "正文", "kind": "longText", "system": true }
      ],
      "actions": [
        {
          "id": "create",
          "label": "创建",
          "kind": "create",
          "system": true,
          "writableFields": ["title", "body"],
          "requiredFields": ["title"]
        },
        { "id": "update", "label": "编辑", "kind": "update", "system": true, "writableFields": ["title", "body"] },
        { "id": "comment", "label": "评论", "kind": "comment", "system": true, "writableFields": [] },
        { "id": "transition", "label": "流转", "kind": "transition", "system": true, "writableFields": [] }
      ]
    }
  ],
  "statuses": [
    { "id": "default", "name": "默认", "category": "todo", "position": 0, "color": "#64748b", "system": true, "enabled": true },
    { "id": "active", "name": "处理中", "category": "active", "position": 1, "color": "#2563eb", "system": true, "enabled": true },
    { "id": "waiting", "name": "等待回复", "category": "waiting", "position": 2, "color": "#d97706", "system": true, "enabled": true, "allowAsInitial": false },
    { "id": "resolved", "name": "已解决", "category": "done", "position": 3, "color": "#059669", "system": true, "enabled": true, "allowAsInitial": false },
    { "id": "done", "name": "完成", "category": "done", "position": 4, "color": "#16a34a", "system": true, "enabled": true, "allowAsInitial": false }
  ],
  "transitions": [
    {
      "id": "start",
      "name": "开始处理",
      "cardType": null,
      "fromStatus": "default",
      "toStatus": "active",
      "writableFields": [],
      "system": true,
      "enabled": true
    },
    {
      "id": "request_reply",
      "name": "请求回复",
      "cardType": "decision",
      "fromStatus": "default",
      "toStatus": "waiting",
      "writableFields": [],
      "system": true,
      "enabled": true
    },
    {
      "id": "submit_reply",
      "name": "提交回复",
      "cardType": "decision",
      "fromStatus": "waiting",
      "toStatus": "resolved",
      "writableFields": ["reply"],
      "requiredFields": ["reply"],
      "system": true,
      "enabled": true
    },
    {
      "id": "complete",
      "name": "完成",
      "cardType": null,
      "fromStatus": null,
      "toStatus": "done",
      "writableFields": [],
      "system": true,
      "enabled": true
    }
  ],
  "hookActionModels": [
    { "id": "transition", "name": "执行流转", "schema": { "transitionId": "string" }, "system": true, "enabled": true },
    { "id": "webhook", "name": "Webhook", "schema": { "url": "string" }, "system": true, "enabled": true },
    { "id": "script", "name": "本地脚本", "schema": { "command": "string" }, "system": true, "enabled": true }
  ],
  "hooks": [
    {
      "id": "decision_reply_transition",
      "name": "回复后流转骨架",
      "event": "decision.replied",
      "match": { "cardType": "decision" },
      "action": { "type": "transition", "transitionId": "submit_reply" },
      "system": true,
      "enabled": false
    }
  ],
  "defaults": {
    "status": "default"
  }
}
