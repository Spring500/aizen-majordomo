{
  "name": "aizen-majordomo",
  "version": "0.1.0",
  "description": "Self-hosted local kanban for humans and AI agents",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "node --experimental-sqlite --no-warnings --import tsx --watch src/index.ts",
    "dev:web": "vite --config web/vite.config.ts --host 127.0.0.1",
    "build:web": "vite build --config web/vite.config.ts",
    "start": "node --experimental-sqlite --no-warnings --import tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/tsconfig.json",
    "prepare": "husky && git config merge.ff false"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@node-rs/argon2": "^2.0.2",
    "hono": "^4.6.14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "husky": "^9.1.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
